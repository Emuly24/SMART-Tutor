# Force HTTPS (redirect HTTP to HTTPS)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

Options -Indexes

<FilesMatch "^(config\.php|update_config\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^\.(htaccess|env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>